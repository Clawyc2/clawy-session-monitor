# Clawy Session Monitor - Environment Variables
# Copy this file to .env and fill in your values

# Telegram Bot Token (get it from @BotFather on Telegram)
CLAWY_SESSION_BOT_TOKEN=your_bot_token_here

# OpenClaw Sessions Path (default for Linux)
OPENCLAW_SESSIONS_PATH=/home/your-user/.openclaw/agents/main/sessions

# OpenClaw Workspace Path (optional)
OPENCLAW_WORKSPACE_PATH=/home/your-user/.openclaw/workspace

# Timezone (optional, default: America/Mexico_City)
TIMEZONE=America/Mexico_City
